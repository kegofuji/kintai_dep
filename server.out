    create table adjustment_requests (
        new_break_minutes INT DEFAULT 0 not null,
        original_break_minutes integer,
        target_date date not null,
        adjustment_request_id bigint generated by default as identity,
        approved_at timestamp(6),
        approved_by_employee_id bigint,
        created_at timestamp(6) not null,
        employee_id bigint not null,
        new_clock_in timestamp(6),
        new_clock_out timestamp(6),
        original_clock_in timestamp(6),
        original_clock_out timestamp(6),
        rejected_at timestamp(6),
        rejected_by_employee_id bigint,
        updated_at timestamp(6) not null,
        reason varchar(500) not null,
        rejection_comment varchar(500),
        status varchar(255) not null check (status in ('PENDING','APPROVED','REJECTED','CANCELLED')),
        primary key (adjustment_request_id)
    )
